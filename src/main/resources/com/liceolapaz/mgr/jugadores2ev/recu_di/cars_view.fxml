<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #1e272e;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liceolapaz.mgr.jugadores2ev.recu_di.controller.CarsController">
    <top>
        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2f3542; -fx-padding: 15px;" BorderPane.alignment="CENTER">
            <Label text="Available Vehicles Catalog" textFill="WHITE">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <HBox alignment="CENTER" spacing="20.0">
                <Label text="Your Favorite Car (Green)" textFill="#2ecc71"><font><Font name="System Bold" size="13.0" /></font></Label>
                <Label text="Global Fan Favorite (Gold)" textFill="#f1c40f"><font><Font name="System Bold" size="13.0" /></font></Label>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <TilePane fx:id="carsContainer" alignment="CENTER" hgap="25.0" vgap="25.0" style="-fx-background-color: #1e272e;">
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                </TilePane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>