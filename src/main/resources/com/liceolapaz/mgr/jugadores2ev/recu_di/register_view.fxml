<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liceolapaz.mgr.jugadores2ev.recu_di.controller.RegisterController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="Create an Account" textFill="WHITE">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Username" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <TextField fx:id="usernameField" promptText="Enter unique username" style="-fx-padding: 8px;" />
    </VBox>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Email" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <TextField fx:id="emailField" promptText="Enter email address" style="-fx-padding: 8px;" />
    </VBox>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Password" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <PasswordField fx:id="passwordField" promptText="At least 6 chars (letters &amp; numbers)" style="-fx-padding: 8px;" />
    </VBox>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Confirm Password" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" style="-fx-padding: 8px;" />
    </VBox>

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true">
        <font>
            <Font name="System Bold" size="12.0" />
        </font>
    </Label>

    <Button fx:id="registerButton" defaultButton="true" maxWidth="300.0" onAction="#handleRegister" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px;" text="Sign Up" />

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Already have an account?" textFill="#bdc3c7" />
        <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #3498db; -fx-font-weight: bold;" text="Sign In" />
    </HBox>
</VBox>