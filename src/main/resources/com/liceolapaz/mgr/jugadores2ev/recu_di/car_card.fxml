<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="cardRoot" alignment="CENTER" prefHeight="320.0" prefWidth="240.0" spacing="8.0" style="-fx-background-color: #2f3542; -fx-background-radius: 10px; -fx-border-color: transparent; -fx-border-width: 3px; -fx-border-radius: 10px;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liceolapaz.mgr.jugadores2ev.recu_di.controller.CarCardController">
    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>

    <ImageView fx:id="carImageView" fitHeight="130.0" fitWidth="200.0" preserveRatio="true" />

    <Label fx:id="brandModelLabel" textFill="WHITE">
        <font><Font name="System Bold" size="16.0" /></font>
    </Label>

    <Label fx:id="specsLabel" textFill="#bdc3c7"><font><Font size="13.0" /></font></Label>
    <Label fx:id="priceLabel" textFill="#2ecc71"><font><Font name="System Bold" size="15.0" /></font></Label>
    <Label fx:id="statusBadge" textFill="WHITE"><font><Font name="System Bold" size="12.0" /></font></Label>

    <Button fx:id="favoriteButton" maxWidth="Infinity" onAction="#handleFavoriteClick" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Set as Favorite" />
</VBox>