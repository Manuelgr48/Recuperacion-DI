<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liceolapaz.mgr.jugadores2ev.recu_di.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Car Management System" textFill="WHITE">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Sign In to your account" textFill="#bdc3c7">
        <font>
            <Font size="14.0" />
        </font>
    </Label>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Username" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <TextField fx:id="usernameField" promptText="Enter username" style="-fx-padding: 10px;" />
    </VBox>

    <VBox maxWidth="300.0" spacing="5.0">
        <Label text="Password" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <PasswordField fx:id="passwordField" promptText="Enter password" style="-fx-padding: 10px;" />
    </VBox>

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true">
        <font>
            <Font name="System Bold" size="12.0" />
        </font>
    </Label>

    <Button fx:id="loginButton" defaultButton="true" maxWidth="300.0" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px;" text="Login" />

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Don't have an account?" textFill="#bdc3c7" />
        <Hyperlink onAction="#goToRegister" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;" text="Sign Up" />
    </HBox>
</VBox>